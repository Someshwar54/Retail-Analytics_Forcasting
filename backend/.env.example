# Copy this file to .env and fill in your values
# Never commit the .env file to version control

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default for local dev — no setup required)
DATABASE_URL=sqlite:///./retail_analytics.db

# PostgreSQL (recommended for staging/production)
# DATABASE_URL=postgresql://retail_user:retail_pass@localhost:5432/retail_analytics

# ── Application ──────────────────────────────────────────────────────────────
DEBUG=false
APP_NAME=Retail Analytics & Forecasting API
APP_VERSION=1.0.0

# ── API ───────────────────────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1
# Comma-separated list of allowed CORS origins (use * for open access in dev)
ALLOWED_ORIGINS=["*"]

# ── ML Configuration ─────────────────────────────────────────────────────────
FORECAST_HORIZON_DAYS=30
LGBM_NUM_BOOST_ROUNDS=500
KMEANS_N_CLUSTERS=4
